# Text provider keys. Configure at least one of GROQ_API_KEY, NVIDIA_API_KEY, or GEMINI_API_KEY.
GROQ_API_KEY=
NVIDIA_API_KEY=
GEMINI_API_KEY=

# Required runtime secrets. Set these in GitHub Actions Secrets for cloud runs.
GEMINI_FALLBACK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_API_KEY=
YOUTUBE_CLIENT_SECRET_JSON=
YOUTUBE_REFRESH_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RUN_TIMEZONE=Asia/Kolkata

# Optional provider and runtime settings.
QWEN_API_KEY=
DREAMINA_API_KEY=
WHISPER_MODEL_SIZE=
DEFAULT_LANGUAGE=hi
DEFAULT_PROVIDER_POLICY=fallback_allowed
VIDEO_DURATION_SECONDS=8
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY_STATUS=private
VIDEO_PROVIDER_PROFILES_JSON=[{"name":"flow_quality","provider":"google_flow","model":"veo-3.1-generate-preview","api_key_env":"GEMINI_API_KEY"},{"name":"openrouter","provider":"openrouter","model":"alibaba/wan-2.6:free","api_key_env":"OPENROUTER_API_KEY"},{"name":"flow_fallback","provider":"google_flow","model":"veo-3.1-lite-generate-preview","api_key_env":"GEMINI_FALLBACK_API_KEY"}]
